PC brikc_emitter {
    // Bootstrap IR/AST -> BIR text emitter.
    // Input: `ir` (typed_program | program/PC AST | statement list)
    // Output: BIR text serialization

    fn int_to_str(n) {
        if (n == 0) { return "0"; }
        if (n == 1) { return "1"; }
        if (n == 2) { return "2"; }
        if (n == 3) { return "3"; }
        if (n == 4) { return "4"; }
        if (n == 5) { return "5"; }
        if (n == 6) { return "6"; }
        if (n == 7) { return "7"; }
        if (n == 8) { return "8"; }
        if (n == 9) { return "9"; }

        let result = "";
        let remaining = n;
        let digits = [];
        loop(20) as _i {
            if (remaining > 0) {
                let dv = MC_03.DIV8(remaining, 10);
                let digit = dv[1];
                let digits = digits.push(digit);
                let remaining = dv[0];
            }
        }

        let dlen = digits.len();
        loop(dlen) as i {
            let d = digits[MC_01.SUB8(MC_01.SUB8(dlen, 1), i)];
            let ds = int_to_str(d);
            let result = MC_40.CONCAT(result, ds);
        }
        return result;
    }

    fn to_text(x) {
        if (x == 0) { return "0"; }
        if (x == 1) { return "1"; }
        if (x == 2) { return "2"; }
        if (x == 3) { return "3"; }
        if (x == 4) { return "4"; }
        if (x == 5) { return "5"; }
        if (x == 6) { return "6"; }
        if (x == 7) { return "7"; }
        if (x == 8) { return "8"; }
        if (x == 9) { return "9"; }
        return x;
    }

    fn append_line(text, line) {
        let t = MC_40.CONCAT(text, line);
        let t = MC_40.CONCAT(t, "\n");
        return t;
    }

    fn index_of_from(arr, name, idx) {
        if (idx >= arr.len()) {
            return MC_01.SUB8(0, 1);
        }
        if (arr[idx] == name) {
            return idx;
        }
        return index_of_from(arr, name, MC_00.ADD8(idx, 1));
    }

    fn index_of(arr, name) {
        return index_of_from(arr, name, 0);
    }

    fn find_or_add_slot(slots, name) {
        let idx = index_of(slots, name);
        if (idx == MC_01.SUB8(0, 1)) {
            let new_slots = slots.push(name);
            let new_idx = MC_01.SUB8(new_slots.len(), 1);
            return [new_slots, new_idx];
        }
        return [slots, idx];
    }

    fn split_monomer(full) {
        // "MC_00.ADD8" -> ["MC_00", "ADD8"]
        let dot = 0;
        let found = 0;
        let n = MC_43.LEN(full);
        loop(n) as i {
            if (found == 0) {
                if (full.char_at(i) == ".") {
                    let found = 1;
                    let dot = i;
                }
            }
        }
        if (found == 0) {
            return [full, ""];
        }

        let left = MC_42.SUBSTR(full, 0, dot);
        let right = MC_42.SUBSTR(full, MC_00.ADD8(dot, 1), MC_01.SUB8(n, MC_00.ADD8(dot, 1)));
        return [left, right];
    }

    fn monomer_opcode(mc_name, op_name) {
        let s = MC_40.CONCAT(mc_name, ".");
        let s = MC_40.CONCAT(s, op_name);
        return s;
    }

    fn binop_instr(op) {
        if (op == "+") { return "ADD_I64"; }
        if (op == "-") { return "SUB_I64"; }
        if (op == "*") { return "MUL_I64"; }
        if (op == "/") { return "MONOMER MC_03.DIV8 2"; }
        if (op == "==") { return "CMP_EQ"; }
        if (op == "!=") { return "CMP_NE"; }
        if (op == "<") { return "CMP_LT"; }
        if (op == ">") { return "CMP_GT"; }
        if (op == "<=") { return "CMP_LE"; }
        if (op == ">=") { return "CMP_GE"; }
        if (op == "&&") { return "MONOMER MC_18.AND 2"; }
        if (op == "||") { return "MONOMER MC_19.OR 2"; }
        return "NOP";
    }

    fn emit_expr(node, code, slots) {
        let k = node[0];

        if (k == "num") {
            let v = to_text(node[1]);
            let line = MC_40.CONCAT("PUSH_I64 ", v);
            let code = code.push(line);
            return [code, slots];
        }

        if (k == "int") {
            let v = to_text(node[1]);
            let line = MC_40.CONCAT("PUSH_I64 ", v);
            let code = code.push(line);
            return [code, slots];
        }

        if (k == "str") {
            let v = to_text(node[1]);
            let line = MC_40.CONCAT("PUSH_STR \"", v);
            let line = MC_40.CONCAT(line, "\"");
            let code = code.push(line);
            return [code, slots];
        }

        if (k == "ident") {
            let vr = find_or_add_slot(slots, node[1]);
            let slots = vr[0];
            let idx = vr[1];
            let line = MC_40.CONCAT("LOAD ", int_to_str(idx));
            let code = code.push(line);
            return [code, slots];
        }

        if (k == "var") {
            let vr = find_or_add_slot(slots, node[1]);
            let slots = vr[0];
            let idx = vr[1];
            let line = MC_40.CONCAT("LOAD ", int_to_str(idx));
            let code = code.push(line);
            return [code, slots];
        }

        if (k == "array") {
            let elems = node[1];
            let elen = elems.len();
            loop(elen) as i {
                let rr = emit_expr(elems[i], code, slots);
                let code = rr[0];
                let slots = rr[1];
            }
            let line = MC_40.CONCAT("ARRAY_NEW (", int_to_str(elen));
            let line = MC_40.CONCAT(line, " elems)");
            let code = code.push(line);
            return [code, slots];
        }

        if (k == "binop") {
            let left = node[2];
            let right = node[3];
            let r1 = emit_expr(left, code, slots);
            let code = r1[0];
            let slots = r1[1];
            let r2 = emit_expr(right, code, slots);
            let code = r2[0];
            let slots = r2[1];

            let line = binop_instr(node[1]);
            let code = code.push(line);
            return [code, slots];
        }

        if (k == "monomer") {
            let args = [];
            let op = "";
            let mono = "";

            if (node.len() == 3) {
                let parts = split_monomer(node[1]);
                let mono = parts[0];
                let op = parts[1];
                let args = node[2];
            } else {
                let mono = node[1];
                let op = node[2];
                let args = node[3];
            }

            let argc = args.len();
            loop(argc) as i {
                let rr = emit_expr(args[i], code, slots);
                let code = rr[0];
                let slots = rr[1];
            }

            let opcode = monomer_opcode(mono, op);
            let line = MC_40.CONCAT("MONOMER ", opcode);
            let line = MC_40.CONCAT(line, " ");
            let line = MC_40.CONCAT(line, int_to_str(argc));
            let code = code.push(line);
            return [code, slots];
        }

        if (k == "call") {
            let fn_name = node[1];
            let args = node[2];
            let argc = args.len();

            loop(argc) as i {
                let rr = emit_expr(args[i], code, slots);
                let code = rr[0];
                let slots = rr[1];
            }

            if (fn_name == "OUTPUT") {
                let line = MC_40.CONCAT("MONOMER OUTPUT ", int_to_str(argc));
                let code = code.push(line);
                return [code, slots];
            }

            let fr = find_or_add_slot(slots, fn_name);
            let slots = fr[0];
            let fslot = fr[1];
            let load = MC_40.CONCAT("LOAD ", int_to_str(fslot));
            let code = code.push(load);
            let call = MC_40.CONCAT("CALL_CLOSURE ", int_to_str(argc));
            let code = code.push(call);
            return [code, slots];
        }

        let code = code.push("PUSH_I64 0");
        return [code, slots];
    }

    fn emit_stmt(stmt, code, slots) {
        let k = stmt[0];

        if (k == "let") {
            let rr = emit_expr(stmt[2], code, slots);
            let code = rr[0];
            let slots = rr[1];

            let vr = find_or_add_slot(slots, stmt[1]);
            let slots = vr[0];
            let idx = vr[1];
            let line = MC_40.CONCAT("STORE ", int_to_str(idx));
            let code = code.push(line);
            return [code, slots];
        }

        if (k == "assign") {
            let rr = emit_expr(stmt[2], code, slots);
            let code = rr[0];
            let slots = rr[1];

            let vr = find_or_add_slot(slots, stmt[1]);
            let slots = vr[0];
            let idx = vr[1];
            let line = MC_40.CONCAT("STORE ", int_to_str(idx));
            let code = code.push(line);
            return [code, slots];
        }

        if (k == "return") {
            let rr = emit_expr(stmt[1], code, slots);
            let code = rr[0];
            let slots = rr[1];
            let code = code.push("RET");
            return [code, slots];
        }

        if (k == "if") {
            let cond = stmt[1];
            let then_body = stmt[2];
            let else_body = stmt[3];

            let rr = emit_expr(cond, code, slots);
            let code = rr[0];
            let slots = rr[1];

            // If true jump over else-entry jump.
            let code = code.push("JUMP_IF 2");

            let elen = else_body.len();
            loop(elen) as i {
                let sr = emit_stmt(else_body[i], code, slots);
                let code = sr[0];
                let slots = sr[1];
            }

            let code = code.push("JUMP 1");

            let tlen = then_body.len();
            loop(tlen) as i {
                let sr = emit_stmt(then_body[i], code, slots);
                let code = sr[0];
                let slots = sr[1];
            }

            return [code, slots];
        }

        if (k == "loop") {
            let count_expr = stmt[1];
            let body = stmt[2];

            let rr = emit_expr(count_expr, code, slots);
            let code = rr[0];
            let slots = rr[1];

            let code = code.push("JUMP_IF 2");
            let code = code.push("JUMP 0");

            let blen = body.len();
            loop(blen) as i {
                let sr = emit_stmt(body[i], code, slots);
                let code = sr[0];
                let slots = sr[1];
            }

            let code = code.push("JUMP -2");
            return [code, slots];
        }

        if (k == "fn") {
            let name = stmt[1];
            let params = stmt[2];
            let body = stmt[3];

            let line = MC_40.CONCAT("MAKE_CLOSURE ", int_to_str(params.len()));
            let code = code.push(line);

            let fr = find_or_add_slot(slots, name);
            let slots = fr[0];
            let fslot = fr[1];
            let line = MC_40.CONCAT("STORE ", int_to_str(fslot));
            let code = code.push(line);

            let blen = body.len();
            loop(blen) as i {
                let sr = emit_stmt(body[i], code, slots);
                let code = sr[0];
                let slots = sr[1];
            }

            let code = code.push("RET");
            return [code, slots];
        }

        let rr = emit_expr(stmt, code, slots);
        return rr;
    }

    fn normalize_program(input) {
        let kind = input[0];

        if (kind == "typed_program") {
            return input[2];
        }

        if (kind == "program") {
            return input;
        }

        if (kind == "PC") {
            return input;
        }

        // Fallback: treat as statement list.
        return ["program", "module", input];
    }

    fn emit_module(input) {
        let program = normalize_program(input);
        let kind = program[0];
        let name = "module";
        let body = [];

        if (kind == "program") {
            let name = program[1];
            let body = program[2];
        }

        if (kind == "PC") {
            let name = program[1];
            let body = program[2];
        }

        let code = [];
        let slots = [];

        let blen = body.len();
        loop(blen) as i {
            let sr = emit_stmt(body[i], code, slots);
            let code = sr[0];
            let slots = sr[1];
        }

        let code = code.push("HALT");

        let vars_line = "";
        let slen = slots.len();
        loop(slen) as i {
            if (i == 0) {
                let vars_line = slots[i];
            } else {
                let vars_line = MC_40.CONCAT(vars_line, ",");
                let vars_line = MC_40.CONCAT(vars_line, slots[i]);
            }
        }

        let out = "";
        let out = append_line(out, "VERSION 1");
        let out = append_line(out, MC_40.CONCAT("MODULE ", name));
        let out = append_line(out, "INPUTS source_0");
        let out = append_line(out, "OUTPUT bir_0");
        let out = append_line(out, MC_40.CONCAT("VARS ", vars_line));
        let out = append_line(out, "STRINGS 0");
        let out = append_line(out, "FUNCTIONS 0");
        let out = append_line(out, "INSTRUCTIONS");

        let clen = code.len();
        loop(clen) as i {
            let out = append_line(out, code[i]);
        }

        return out;
    }

    let bir = emit_module(ir);
    OUTPUT bir;
}
