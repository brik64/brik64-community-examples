PC test_elf_writer {
    // ============================================================
    // Test suite para la infraestructura de buffer de bytes ELF.
    // Verifica: byte_at, write_u16_le, write_u32_le, write_u64_le,
    //           startup_stub_bytes.
    // OUTPUT 0 = todos los tests pasan.
    // OUTPUT N = N tests fallaron.
    // ============================================================

    fn div256(n) {
        let q = 0;
        let r = n;
        loop(1000000) as _d {
            if (r < 256) { return q; }
            let r = r - 256;
            let q = q + 1;
        }
        return q;
    }

    fn mod256(n) {
        let r = n;
        loop(1000000) as _m {
            if (r < 256) { return r; }
            let r = r - 256;
        }
        return r;
    }

    fn byte_at(value, shift) {
        let v = value;
        if (shift == 0) { return mod256(v); }
        let v = div256(v);
        if (shift == 1) { return mod256(v); }
        let v = div256(v);
        if (shift == 2) { return mod256(v); }
        let v = div256(v);
        if (shift == 3) { return mod256(v); }
        let v = div256(v);
        if (shift == 4) { return mod256(v); }
        let v = div256(v);
        if (shift == 5) { return mod256(v); }
        let v = div256(v);
        if (shift == 6) { return mod256(v); }
        let v = div256(v);
        return mod256(v);
    }

    fn write_u16_le(buf, value) {
        let buf = buf.push(byte_at(value, 0));
        let buf = buf.push(byte_at(value, 1));
        return buf;
    }

    fn write_u32_le(buf, value) {
        let buf = buf.push(byte_at(value, 0));
        let buf = buf.push(byte_at(value, 1));
        let buf = buf.push(byte_at(value, 2));
        let buf = buf.push(byte_at(value, 3));
        return buf;
    }

    fn write_u64_le(buf, value) {
        let buf = buf.push(byte_at(value, 0));
        let buf = buf.push(byte_at(value, 1));
        let buf = buf.push(byte_at(value, 2));
        let buf = buf.push(byte_at(value, 3));
        let buf = buf.push(byte_at(value, 4));
        let buf = buf.push(byte_at(value, 5));
        let buf = buf.push(byte_at(value, 6));
        let buf = buf.push(byte_at(value, 7));
        return buf;
    }

    fn startup_stub_bytes() {
        let b = [];
        // xor rdi, rdi
        let b = b.push(72);  let b = b.push(49);  let b = b.push(255);
        // mov rsi, 0x400000
        let b = b.push(72);  let b = b.push(199); let b = b.push(198);
        let b = b.push(0);   let b = b.push(0);   let b = b.push(64);  let b = b.push(0);
        // mov edx, 3
        let b = b.push(186); let b = b.push(3);   let b = b.push(0);
        let b = b.push(0);   let b = b.push(0);
        // mov r10d, 0x22
        let b = b.push(65);  let b = b.push(186); let b = b.push(34);
        let b = b.push(0);   let b = b.push(0);   let b = b.push(0);
        // mov r8, -1
        let b = b.push(73);  let b = b.push(199); let b = b.push(192);
        let b = b.push(255); let b = b.push(255); let b = b.push(255); let b = b.push(255);
        // xor r9, r9
        let b = b.push(77);  let b = b.push(49);  let b = b.push(201);
        // mov eax, 9
        let b = b.push(184); let b = b.push(9);   let b = b.push(0);
        let b = b.push(0);   let b = b.push(0);
        // syscall
        let b = b.push(15);  let b = b.push(5);
        // mov r15, rax
        let b = b.push(73);  let b = b.push(137); let b = b.push(199);
        // xor rbp, rbp
        let b = b.push(72);  let b = b.push(49);  let b = b.push(237);
        // call rel32=10
        let b = b.push(232); let b = b.push(10);  let b = b.push(0);
        let b = b.push(0);   let b = b.push(0);
        // movzx edi, al
        let b = b.push(15);  let b = b.push(182); let b = b.push(248);
        // mov eax, 60
        let b = b.push(184); let b = b.push(60);  let b = b.push(0);
        let b = b.push(0);   let b = b.push(0);
        // syscall
        let b = b.push(15);  let b = b.push(5);
        return b;
    }

    // ── Tests ──
    let errors = 0;

    // Test 1: byte_at extrae LSB correctamente
    // byte_at(2, 0) debe ser 2
    let t1 = byte_at(2, 0);
    if (t1 == 2) { let _ok = 0; } else { let errors = errors + 1; }

    // Test 2: byte_at extrae byte 1 de un valor < 256
    // byte_at(2, 1) debe ser 0 (div256(2)=0, mod256(0)=0)
    let t2 = byte_at(2, 1);
    if (t2 == 0) { let _ok = 0; } else { let errors = errors + 1; }

    // Test 3: byte_at extrae byte 2 de un valor de 3 bytes
    // 0x010203 = 66051: byte0=3, byte1=2, byte2=1
    let t3a = byte_at(66051, 0);
    if (t3a == 3) { let _ok = 0; } else { let errors = errors + 1; }
    let t3b = byte_at(66051, 1);
    if (t3b == 2) { let _ok = 0; } else { let errors = errors + 1; }
    let t3c = byte_at(66051, 2);
    if (t3c == 1) { let _ok = 0; } else { let errors = errors + 1; }

    // Test 4: write_u16_le produce [2, 0] para ET_EXEC=2
    let buf16 = [];
    let buf16 = write_u16_le(buf16, 2);
    if (buf16.len() == 2) { let _ok = 0; } else { let errors = errors + 1; }
    if (buf16[0] == 2)    { let _ok = 0; } else { let errors = errors + 1; }
    if (buf16[1] == 0)    { let _ok = 0; } else { let errors = errors + 1; }

    // Test 5: write_u32_le produce [1, 0, 0, 0] para EV_CURRENT=1
    let buf32 = [];
    let buf32 = write_u32_le(buf32, 1);
    if (buf32.len() == 4) { let _ok = 0; } else { let errors = errors + 1; }
    if (buf32[0] == 1)    { let _ok = 0; } else { let errors = errors + 1; }
    if (buf32[1] == 0)    { let _ok = 0; } else { let errors = errors + 1; }
    if (buf32[2] == 0)    { let _ok = 0; } else { let errors = errors + 1; }
    if (buf32[3] == 0)    { let _ok = 0; } else { let errors = errors + 1; }

    // Test 6: write_u64_le produce [8, 0, 0, 0, 0, 0, 0, 0] para valor 8
    let buf64 = [];
    let buf64 = write_u64_le(buf64, 8);
    if (buf64.len() == 8) { let _ok = 0; } else { let errors = errors + 1; }
    if (buf64[0] == 8)    { let _ok = 0; } else { let errors = errors + 1; }
    if (buf64[1] == 0)    { let _ok = 0; } else { let errors = errors + 1; }
    if (buf64[2] == 0)    { let _ok = 0; } else { let errors = errors + 1; }
    if (buf64[3] == 0)    { let _ok = 0; } else { let errors = errors + 1; }
    if (buf64[4] == 0)    { let _ok = 0; } else { let errors = errors + 1; }
    if (buf64[5] == 0)    { let _ok = 0; } else { let errors = errors + 1; }
    if (buf64[6] == 0)    { let _ok = 0; } else { let errors = errors + 1; }
    if (buf64[7] == 0)    { let _ok = 0; } else { let errors = errors + 1; }

    // Test 7: write_u64_le con valor multi-byte 0x010203 = 66051
    // Esperado: [3, 2, 1, 0, 0, 0, 0, 0]
    let buf64b = [];
    let buf64b = write_u64_le(buf64b, 66051);
    if (buf64b[0] == 3) { let _ok = 0; } else { let errors = errors + 1; }
    if (buf64b[1] == 2) { let _ok = 0; } else { let errors = errors + 1; }
    if (buf64b[2] == 1) { let _ok = 0; } else { let errors = errors + 1; }
    if (buf64b[3] == 0) { let _ok = 0; } else { let errors = errors + 1; }

    // Test 8: startup_stub_bytes tiene exactamente 59 bytes
    let stub = startup_stub_bytes();
    if (stub.len() == 59) { let _ok = 0; } else { let errors = errors + 1; }

    // Test 9: startup_stub_bytes empieza con magic ELF del mmap
    // Primer byte: 0x48 = 72 (xor rdi, rdi — prefijo REX)
    if (stub[0] == 72)  { let _ok = 0; } else { let errors = errors + 1; }
    // Segundo byte: 0x31 = 49
    if (stub[1] == 49)  { let _ok = 0; } else { let errors = errors + 1; }
    // Tercer byte: 0xFF = 255 (rdi como registro destino en xor)
    if (stub[2] == 255) { let _ok = 0; } else { let errors = errors + 1; }

    // Test 10: byte 44 es 0xE8=232 (opcode call rel32)
    if (stub[44] == 232) { let _ok = 0; } else { let errors = errors + 1; }
    // byte 45 es 0x0A=10 (rel32 LSB, call +10 para code_offset=0)
    if (stub[45] == 10)  { let _ok = 0; } else { let errors = errors + 1; }

    OUTPUT errors;
}
