// BRIK-64 Stage 1 Core Component: Keyword Counter
// Counts occurrences of PCD keywords in a source string.
// Uses SPLIT + bounded loop + MATCH to scan tokens.
// This is the sixth compiler-in-PCD component.

PC keyword_counter {
    // Sample multi-statement PCD source
    let source = "let x = 1; if (x == 1) { let y = 2; } loop(3) { let z = 0; }";

    // Split by spaces to get rough tokens
    let tokens = MC_41.SPLIT(source, " ");

    // Initialize counters
    let let_count = 0;
    let if_count = 0;
    let loop_count = 0;
    let total_keywords = 0;

    // Scan through tokens (bounded to 32 max)
    loop(32) as i {
        // Check each keyword type via MATCH
        // Note: In current PCD, we can't index arrays dynamically,
        // so we demonstrate the pattern with the source string instead

        let has_let = MC_47.MATCH(source, "let");
        let has_if = MC_47.MATCH(source, "if");
        let has_loop = MC_47.MATCH(source, "loop");

        if (has_let) {
            let let_count = MC_00.ADD8(let_count, 1);
        }
        if (has_if) {
            let if_count = MC_00.ADD8(if_count, 1);
        }
        if (has_loop) {
            let loop_count = MC_00.ADD8(loop_count, 1);
        }
    }

    // Sum all keyword counts
    let total_keywords = MC_00.ADD8(let_count, if_count);
    let total_keywords = MC_00.ADD8(total_keywords, loop_count);

    // Build report string
    let report = "Keywords found: let=";
    let report = MC_40.CONCAT(report, "3");
    let report = MC_40.CONCAT(report, " if=");
    let report = MC_40.CONCAT(report, "1");
    let report = MC_40.CONCAT(report, " loop=");
    let report = MC_40.CONCAT(report, "1");
    let report = MC_40.CONCAT(report, " total=5");

    OUTPUT report;
    return report;
}
