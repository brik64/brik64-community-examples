// Policy: Memory Bound
// Blocks programs with excessive memory operations (>100 MC_16-MC_23 calls)

PC memory_bound {
    import "ast_inspect.pcd";

    fn check(mc_ids) {
        let mem_ops = count_in_range(mc_ids, 16, 23);
        if (mem_ops > 100) { return 1; }
        return 0;
    }

    OUTPUT 0;
}
