PC math_lib {

  fn min(a, b) {
    if (a < b) {
      return a;
    }
    return b;
  }

  fn max(a, b) {
    if (a > b) {
      return a;
    }
    return b;
  }

  fn abs(n) {
    if (n < 0) {
      return 0 - n;
    }
    return n;
  }

  fn pow(base, exp) {
    let result = 1;
    loop(exp) as i {
      let result = result * base;
    }
    return result;
  }

  fn sqrt(n) {
    if (n < 2) {
      return n;
    }
    let guess = n / 2;
    loop(64) as i {
      let next = (guess + n / guess) / 2;
      if (next >= guess) {
        return guess;
      }
      let guess = next;
    }
    return guess;
  }

  fn clamp(val, lo, hi) {
    if (val < lo) {
      return lo;
    }
    if (val > hi) {
      return hi;
    }
    return val;
  }

  fn gcd(a, b) {
    let x = a;
    let y = b;
    if (x < 0) {
      let x = 0 - x;
    }
    if (y < 0) {
      let y = 0 - y;
    }
    loop(1000) as i {
      if (y == 0) {
        return x;
      }
      let rem = x - (x / y) * y;
      let x = y;
      let y = rem;
    }
    return x;
  }

  fn factorial(n) {
    let result = 1;
    loop(n) as i {
      let result = result * (i + 1);
    }
    return result;
  }

  OUTPUT 0;
}
