PC string_lib {

  fn split(s, delimiter) {
    let result = MC_41.SPLIT(s, delimiter);
    return result;
  }

  fn join(arr, delimiter) {
    let n = arr.len();
    if (n == 0) {
      return "";
    }
    let out = arr[0];
    let i = 1;
    loop(n) {
      if (i < n) {
        let out = MC_40.CONCAT(out, delimiter);
        let out = MC_40.CONCAT(out, arr[i]);
        let i = i + 1;
      }
    }
    return out;
  }

  fn trim(s) {
    let result = MC_46.TRIM(s);
    return result;
  }

  fn replace(s, from, to) {
    let parts = MC_41.SPLIT(s, from);
    let n = parts.len();
    if (n == 0) {
      return "";
    }
    let out = parts[0];
    let i = 1;
    loop(n) {
      if (i < n) {
        let out = MC_40.CONCAT(out, to);
        let out = MC_40.CONCAT(out, parts[i]);
        let i = i + 1;
      }
    }
    return out;
  }

  fn starts_with(s, prefix) {
    let plen = MC_43.LEN(prefix);
    let slen = MC_43.LEN(s);
    if (slen < plen) {
      return 0;
    }
    let sub = MC_42.SUBSTR(s, 0, plen);
    if (sub == prefix) {
      return 1;
    }
    return 0;
  }

  fn ends_with(s, suffix) {
    let suflen = MC_43.LEN(suffix);
    let slen = MC_43.LEN(s);
    if (slen < suflen) {
      return 0;
    }
    let start = slen - suflen;
    let sub = MC_42.SUBSTR(s, start, suflen);
    if (sub == suffix) {
      return 1;
    }
    return 0;
  }

  fn to_upper(s) {
    let result = MC_44.UPPER(s);
    return result;
  }

  fn to_lower(s) {
    let result = MC_45.LOWER(s);
    return result;
  }

  fn contains(s, substr) {
    let result = MC_47.MATCH(s, substr);
    if (result == 1) {
      return 1;
    }
    return 0;
  }

  fn char_at(s, index) {
    let ch = MC_42.SUBSTR(s, index, 1);
    return ch;
  }

  fn repeat(s, n) {
    if (n < 1) {
      return "";
    }
    let out = s;
    let i = 1;
    loop(n) {
      if (i < n) {
        let out = MC_40.CONCAT(out, s);
        let i = i + 1;
      }
    }
    return out;
  }

  fn pad_left(s, total_len, ch) {
    let slen = MC_43.LEN(s);
    if (slen >= total_len) {
      return s;
    }
    let pad_count = total_len - slen;
    let pad = "";
    let i = 0;
    loop(total_len) {
      if (i < pad_count) {
        let pad = MC_40.CONCAT(pad, ch);
        let i = i + 1;
      }
    }
    let result = MC_40.CONCAT(pad, s);
    return result;
  }

  OUTPUT 0;
}
